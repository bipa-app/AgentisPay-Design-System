{
  "name": "@bipa/ui-web",
  "version": "0.1.0",
  "description": "AgentisPay web component library — Svelte",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "package": "svelte-kit sync && svelte-package -o dist",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts"
    },
    "./Button": {
      "svelte": "./src/lib/components/Button/index.ts"
    },
    "./Input": {
      "svelte": "./src/lib/components/Input/index.ts"
    },
    "./Badge": {
      "svelte": "./src/lib/components/Badge/index.ts"
    },
    "./Card": {
      "svelte": "./src/lib/components/Card/index.ts"
    },
    "./Alert": {
      "svelte": "./src/lib/components/Alert/index.ts"
    },
    "./Modal": {
      "svelte": "./src/lib/components/Modal/index.ts"
    },
    "./Toast": {
      "svelte": "./src/lib/components/Toast/index.ts"
    },
    "./Table": {
      "svelte": "./src/lib/components/Table/index.ts"
    },
    "./Tabs": {
      "svelte": "./src/lib/components/Tabs/index.ts"
    },
    "./Sidebar": {
      "svelte": "./src/lib/components/Sidebar/index.ts"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "storybook": "^10.2.17",
    "@storybook/sveltekit": "^10.2.17",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "vitest": "^4.1.0",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
